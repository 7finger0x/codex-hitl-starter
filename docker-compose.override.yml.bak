# Docker Compose override for Supabase edge-runtime memory limits
# This file adds memory constraints to prevent OOM kills of edge functions
# Place this file in the same directory as the Supabase CLI-generated docker-compose.yml
# Reference: https://docs.docker.com/compose/compose-file/#services

services:
  # Edge Runtime - Supabase serverless functions
  # Memory limit set to 2GB to prevent runaway functions from consuming all host memory
  supabase_edge_runtime_codex-hitl-starter:
    mem_limit: 2g
    memswap_limit: 2g
    healthcheck:
      test: 
        - CMD
        - wget
        - --no-verbose
        - --tries=1
        - --spider
        - http://127.0.0.1:8081/_internal/health
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s
