# Safe local-only defaults. Copy to a gitignored .env.local and supply synthetic values.
COMPOSE_PROJECT_NAME=platform-foundation-local
PLATFORM_DEPLOYMENT_ENVIRONMENT=local

POSTGRES_DB=platform_foundation_hcp03
PLATFORM_DATABASE_COMMENT=DISPOSABLE:002-platform-foundation:HCP-03
POSTGRES_PASSWORD=

SITE_URL=http://127.0.0.1:3000
ADDITIONAL_REDIRECT_URLS=http://127.0.0.1:3000/**
JWT_EXPIRY=3600
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

GF_SECURITY_ADMIN_PASSWORD=

# Fixed loopback bindings; changing one invalidates HCP-04 approval.
WEB_PORT=3000
API_PORT=8080
POSTGRES_PORT=55432
AUTH_PORT=55433
REST_PORT=55434
REALTIME_PORT=55435
STORAGE_PORT=55436
OTLP_GRPC_PORT=54317
OTLP_HTTP_PORT=54318
GRAFANA_PORT=53000
