        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service_instance_id) (rate(otelcol_processor_dropped_log_records_total[5m]))",
