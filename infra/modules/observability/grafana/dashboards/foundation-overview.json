      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "increase(foundation_audit_persist_failures_total[5m])",
          "legendFormat": "audit persistence",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "increase(foundation_configuration_activation_failures_total[5m])",
          "legendFormat": "configuration activation",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Fail-closed control failures",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "foundation-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 9,
        "x": 15,
        "y": 0
