          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum by (service_instance_id) (rate(otelcol_processor_dropped_spans_total[5m]))",
          "legendFormat": "spans {{service_instance_id}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Collector drops",
      "type": "timeseries"
