{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.trading-os.example/v1/domain-event.schema.json",
  "title": "Platform Domain Event Envelope",
  "description": "Proposed Phase 1 contract. Implementation requires HCP-02 approval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "tenant_id",
    "environment_id",
    "producer",
    "subject",
    "actor",
    "correlation_id",
    "causation_id",
    "idempotency_key",
    "occurred_at",
    "trace_context",
    "data"
  ],
  "properties": {
    "event_id": { "$ref": "#/$defs/opaqueId" },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*\\.v[1-9][0-9]*$",
      "examples": ["tenant.created.v1"]
    },
    "schema_version": { "type": "integer", "minimum": 1 },
    "tenant_id": { "$ref": "#/$defs/opaqueId" },
    "environment_id": { "$ref": "#/$defs/opaqueId" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "version"],
      "properties": {
        "service": { "type": "string", "minLength": 1, "maxLength": 100 },
        "version": { "type": "string", "minLength": 1, "maxLength": 100 }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "version"],
      "properties": {
        "type": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "id": { "$ref": "#/$defs/opaqueId" },
        "version": { "type": "integer", "minimum": 1 }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "enum": ["user", "service", "system"] },
        "id": { "$ref": "#/$defs/opaqueId" },
        "session_id": { "$ref": "#/$defs/nullableOpaqueId" }
      }
    },
    "correlation_id": { "$ref": "#/$defs/opaqueId" },
    "causation_id": { "$ref": "#/$defs/nullableOpaqueId" },
    "idempotency_key": { "type": "string", "minLength": 16, "maxLength": 255 },
    "occurred_at": { "$ref": "#/$defs/timestamp" },
    "published_at": { "$ref": "#/$defs/nullableTimestamp" },
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceparent"],
      "properties": {
        "traceparent": {
          "type": "string",
          "pattern": "^[0-9a-f]{2}-[0-9a-f]{32}-[0-9a-f]{16}-[0-9a-f]{2}$"
        },
        "tracestate": { "type": ["string", "null"], "maxLength": 512 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string", "minLength": 1, "maxLength": 100 },
        "source_reference": { "type": ["string", "null"], "maxLength": 500 }
      }
    },
    "data": { "type": "object" }
  },
  "$defs": {
    "opaqueId": {
      "type": "string",
      "format": "uuid",
      "minLength": 36,
      "maxLength": 36
    },
    "nullableOpaqueId": {
      "oneOf": [
        { "$ref": "#/$defs/opaqueId" },
        { "type": "null" }
      ]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "nullableTimestamp": {
      "oneOf": [
        { "$ref": "#/$defs/timestamp" },
        { "type": "null" }
      ]
    }
  }
}
