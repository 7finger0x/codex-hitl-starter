{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.trading-os.example/v1/platform-configuration.schema.json",
  "title": "Platform Foundation Configuration",
  "description": "Schema-valid, tenant/environment-scoped configuration. Secret values are forbidden. Proposed; HCP-02 applies.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "capabilities", "session", "audit", "events", "limits"],
  "properties": {
    "schema_version": { "const": 1 },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" }
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idle_timeout_seconds", "absolute_timeout_seconds", "step_up_max_age_seconds"],
      "properties": {
        "idle_timeout_seconds": { "type": "integer", "minimum": 300, "maximum": 86400 },
        "absolute_timeout_seconds": { "type": "integer", "minimum": 900, "maximum": 2592000 },
        "step_up_max_age_seconds": { "type": "integer", "minimum": 60, "maximum": 86400 }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fail_closed_actions", "export_retention_days"],
      "properties": {
        "fail_closed_actions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$" }
        },
        "export_retention_days": { "type": "integer", "minimum": 1, "maximum": 3650 }
      }
    },
    "events": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_seconds", "max_attempts", "base_retry_seconds"],
      "properties": {
        "lease_seconds": { "type": "integer", "minimum": 5, "maximum": 3600 },
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 100 },
        "base_retry_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_requests_per_minute", "audit_export_rows"],
      "properties": {
        "api_requests_per_minute": { "type": "integer", "minimum": 1 },
        "audit_export_rows": { "type": "integer", "minimum": 1 }
      }
    },
    "secret_references": {
      "type": "object",
      "description": "Opaque references only; keys and values are identifiers, never credentials.",
      "propertyNames": { "pattern": "^[a-z][a-z0-9_.-]*$" },
      "additionalProperties": { "type": "string", "pattern": "^secret-ref://[A-Za-z0-9._/-]+$" }
    }
  }
}
