{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.ai-trading-os.example/v1/traceability.schema.json",
  "title": "Requirement Traceability Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_revision", "nodes", "edges", "summary", "graph_digest"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "source_revision": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{40,64}$"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mandatory_requirements",
        "covered_requirements",
        "mandatory_gaps",
        "dangling_links",
        "duplicate_links",
        "result"
      ],
      "properties": {
        "mandatory_requirements": {
          "type": "integer",
          "minimum": 0
        },
        "covered_requirements": {
          "type": "integer",
          "minimum": 0
        },
        "mandatory_gaps": {
          "type": "integer",
          "minimum": 0
        },
        "dangling_links": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_links": {
          "type": "integer",
          "minimum": 0
        },
        "result": {
          "type": "string",
          "enum": ["pass", "fail"]
        }
      }
    },
    "graph_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "summary": {
            "properties": { "result": { "const": "pass" } }
          }
        }
      },
      "then": {
        "properties": {
          "summary": {
            "properties": {
              "mandatory_gaps": { "const": 0 },
              "dangling_links": { "const": 0 },
              "duplicate_links": { "const": 0 }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "mandatory", "source"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "kind": {
          "type": "string",
          "enum": [
            "source_revision",
            "paper_requirement",
            "feature_requirement",
            "acceptance_scenario",
            "task",
            "implementation",
            "automated_test",
            "acceptance_check",
            "evidence"
          ]
        },
        "mandatory": {
          "type": "boolean"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "type"],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "derived_from",
            "specified_by",
            "accepted_by",
            "planned_by",
            "implemented_by",
            "tested_by",
            "verified_by",
            "evidenced_by"
          ]
        }
      }
    }
  }
}
