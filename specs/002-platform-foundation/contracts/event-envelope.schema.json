{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.ai-trading-os.example/v1/event-envelope.schema.json",
  "title": "Platform Domain Event Envelope",
  "description": "Superseded planning sketch retained for transparency; domain-event.schema.json is the proposed canonical draft. This file is not implementation authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "occurred_at",
    "recorded_at",
    "tenant_id",
    "environment_id",
    "producer",
    "subject",
    "aggregate",
    "actor",
    "correlation_id",
    "idempotency_key",
    "trace_context",
    "data",
    "provenance"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9]*)+$",
      "maxLength": 160
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[1-9][0-9]*\\.[0-9]+\\.[0-9]+$"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "format": "uuid"
    },
    "environment_id": {
      "type": "string",
      "format": "uuid"
    },
    "producer": {
      "$ref": "#/$defs/typedIdentity"
    },
    "subject": {
      "$ref": "#/$defs/typedIdentity"
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "version"],
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]{1,127}$"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "ordering_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["user", "service", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "membership_id": {
          "type": "string",
          "format": "uuid"
        },
        "service_identity_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "causation_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 16,
      "maxLength": 255
    },
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["traceparent"],
      "properties": {
        "traceparent": {
          "type": "string",
          "pattern": "^[0-9a-f]{2}-[0-9a-f]{32}-[0-9a-f]{16}-[0-9a-f]{2}$"
        },
        "tracestate": {
          "type": "string",
          "maxLength": 512
        }
      }
    },
    "data": {
      "type": "object"
    },
    "data_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_revision", "policy_version", "config_version"],
      "properties": {
        "source_revision": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{40,64}$"
        },
        "policy_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "config_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    }
  },
  "$defs": {
    "typedIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]{1,127}$"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      }
    }
  }
}
