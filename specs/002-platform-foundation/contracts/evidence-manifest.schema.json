{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.ai-trading-os.example/v1/evidence-manifest.schema.json",
  "title": "Platform Verification Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "source",
    "toolchain",
    "checks",
    "security",
    "container",
    "traceability",
    "overall",
    "completion_claim_allowed"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "worktree_state", "worktree_digest"],
      "properties": {
        "revision": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{40,64}$"
        },
        "branch": {
          "type": ["string", "null"]
        },
        "worktree_state": {
          "type": "string",
          "enum": ["clean", "documented-dirty"]
        },
        "worktree_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "documented_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "toolchain": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "policy_versions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "version", "digest"],
        "properties": {
          "key": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "digest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "security": {
      "$ref": "#/$defs/checkGroup"
    },
    "container": {
      "$ref": "#/$defs/checkGroup"
    },
    "deployment": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "environment",
            "revision",
            "configuration_digest",
            "migration_digest",
            "health",
            "result"
          ],
          "properties": {
            "environment": {
              "type": "string",
              "enum": ["preview", "development"]
            },
            "revision": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{40,64}$"
            },
            "configuration_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "migration_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "health": {
              "type": "string",
              "enum": ["pass", "fail"]
            },
            "result": {
              "type": "string",
              "enum": ["pass", "fail"]
            },
            "approved_reference": {
              "type": "string"
            }
          }
        }
      ]
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["graph_digest", "mandatory_gaps", "dangling_links", "duplicate_links", "result"],
      "properties": {
        "graph_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "mandatory_gaps": {
          "type": "integer",
          "minimum": 0
        },
        "dangling_links": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_links": {
          "type": "integer",
          "minimum": 0
        },
        "result": {
          "type": "string",
          "enum": ["pass", "fail"]
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "accepted"],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "accepted": {
            "type": "boolean"
          },
          "approval_reference": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "overall": {
      "type": "string",
      "enum": ["pass", "fail", "incomplete"]
    },
    "completion_claim_allowed": {
      "type": "boolean"
    },
    "manifest_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["completion_claim_allowed"],
        "properties": { "completion_claim_allowed": { "const": true } }
      },
      "then": {
        "required": ["started_at", "completed_at"],
        "properties": {
          "overall": { "const": "pass" },
          "checks": {
            "items": {
              "properties": { "result": { "const": "pass" } }
            }
          },
          "security": {
            "properties": { "result": { "const": "pass" } }
          },
          "container": {
            "properties": { "result": { "const": "pass" } }
          },
          "traceability": {
            "properties": {
              "mandatory_gaps": { "const": 0 },
              "dangling_links": { "const": 0 },
              "duplicate_links": { "const": 0 },
              "result": { "const": "pass" }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["overall"],
        "properties": { "overall": { "enum": ["fail", "incomplete"] } }
      },
      "then": {
        "properties": { "completion_claim_allowed": { "const": false } }
      }
    }
  ],
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "requirements",
        "command_id",
        "started_at",
        "completed_at",
        "exit_code",
        "result",
        "output_digest"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9-]{2,63}$"
        },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "command_id": {
          "type": "string"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "exit_code": {
          "type": "integer"
        },
        "result": {
          "type": "string",
          "enum": ["pass", "fail", "skipped"]
        },
        "output_digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "checkGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checks", "result"],
      "properties": {
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        },
        "result": {
          "type": "string",
          "enum": ["pass", "fail", "incomplete"]
        }
      }
    }
  }
}
